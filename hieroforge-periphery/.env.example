# HieroForge Periphery – Quoter deployment and verification
# Copy to .env and set your values. Do not commit .env.

# -----------------------------------------------------------------------------
# Required for deployment
# -----------------------------------------------------------------------------
# ECDSA / EVM account with HBAR for gas (e.g. same as core)
PRIVATE_KEY=0x...

# PoolManager address from hieroforge-core (deploy PoolManager there first)
POOL_MANAGER_ADDRESS=0xc96474B027344d486a0963B3Da45F9a6c34AA96B

# PositionManager uses standard ERC721 for position NFTs (no HTS_NFT_TOKEN needed for testing).
# Optional (for future HTS): HTS_NFT_TOKEN=0x...

# -----------------------------------------------------------------------------
# After deploy
# -----------------------------------------------------------------------------
# Quoter: scripts/deploy-quoter.sh → then ./scripts/verify-contracts.sh Quoter
QUOTER_ADDRESS=0xb0649244102C565653994bAd0F7473914037d459

# PositionManager: scripts/deploy-position-manager.sh → then ./scripts/verify-contracts.sh PositionManager
POSITION_MANAGER_ADDRESS=0x21ADCD6DE84afE088CD322B9ebdF7dfDF33f0B5A

# UniversalRouter: scripts/deploy.sh router → requires POOL_MANAGER_ADDRESS + POSITION_MANAGER_ADDRESS
ROUTER_ADDRESS=0x993027e4e258310DD872c132db5e9DEbF9578631

# -----------------------------------------------------------------------------
# Verification (scripts/verify-contracts.sh)
# -----------------------------------------------------------------------------
# Hedera Testnet=296, Mainnet=295
# CHAIN_ID=296

# Optional: only prepare manual verification bundles
# VERIFY_MANUAL=1

# Optional: poll until verification completes
# VERIFY_WATCH=1

# -----------------------------------------------------------------------------
# RPC (optional; scripts use Foundry alias 'testnet' from foundry.toml if unset)
# -----------------------------------------------------------------------------
# RPC_URL=https://testnet.hashio.io/api

# -----------------------------------------------------------------------------
# Add liquidity via PositionManager (scripts/add-liquidity-position-manager.sh)
# -----------------------------------------------------------------------------
# CURRENCY0_ADDRESS=0x...
# CURRENCY1_ADDRESS=0x...
# AMOUNT0=1000000
# AMOUNT1=1000000
# Optional: FEE=3000, TICK_SPACING=60, TICK_LOWER=-120, TICK_UPPER=120, OWNER=0x...
# LIQUIDITY: default 1e8 (works with AMOUNT0/AMOUNT1=10e6). Use 1e18 only if AMOUNT0 and AMOUNT1 are ~6e15+ each.
# Local HTS node (same emulation as tests, no --ffi): LOCAL_HTS_EMULATION=1 RPC_URL=local

# -----------------------------------------------------------------------------
# Hedera local node (localhost:7546) – deploy + add liquidity in one shot
# -----------------------------------------------------------------------------
# Use an Alias ECDSA key from: cd hedera-local-node && hedera generate-accounts 5
# Copy a private key from the "Alias ECDSA keys" table, then:
# PRIVATE_KEY=0x...   OR   LOCAL_NODE_OPERATOR_PRIVATE_KEY=0x...
# Run: ./scripts/run-deploy-and-add-liquidity-local.sh
# See: https://docs.hedera.com/hedera/tutorials/local-node/how-to-set-up-a-hedera-local-node

# -----------------------------------------------------------------------------
# Deploy and verify in one go
# -----------------------------------------------------------------------------
# DEPLOY_AND_VERIFY=1 ./scripts/deploy-quoter.sh
# DEPLOY_AND_VERIFY=1 ./scripts/deploy-position-manager.sh

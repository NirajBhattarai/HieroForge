# WalletConnect Project ID (required for HashPack).
# Get one at https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Hedera network: mainnet | testnet | previewnet
VITE_HEDERA_NETWORK=testnet

# PoolManager contract address (after running the deploy script)
# VITE_POOL_MANAGER_ADDRESS=0x...

# Quoter contract address (hieroforge-periphery; required for swap quotes)
VITE_QUOTER_ADDRESS=0xb1d21E7EDB55428394e2A6A0C2Ba314C5B859a74

# Token addresses: edit TOKEN_ADDRESSES in src/constants.ts (HBAR, USDC, TokenA).

# Hedera EVM chain ID (296 = testnet, 295 = mainnet)
VITE_CHAIN_ID=296

# PositionManager contract address (after running the deploy script)
VITE_POSITION_MANAGER_ADDRESS=0x...




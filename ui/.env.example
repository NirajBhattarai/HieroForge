# Next.js / HieroForge UI – copy to ui/.env (do not commit)

# WalletConnect Project ID (required for HashPack). Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Hedera network: mainnet | testnet | previewnet
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_CHAIN_ID=296
NEXT_PUBLIC_RPC_URL=https://testnet.hashio.io/api

# Contract addresses — copy from hieroforge-periphery/.env (see repo root ENV.md)
NEXT_PUBLIC_POOL_MANAGER_ADDRESS=0x32d94413c02b5bEfDED60c66b632852f1291474f
NEXT_PUBLIC_POSITION_MANAGER_ADDRESS=0xEe7E178FCB3865eD320E0Ab69e5dB24162e5AcE9
NEXT_PUBLIC_ROUTER_ADDRESS=0x3f510350f62f02B4Db300d859059d022867350D2
NEXT_PUBLIC_QUOTER_ADDRESS=0x56D8416bc825d8C44BF466Af146E0AC582F62600

# Hook contract addresses
NEXT_PUBLIC_TWAP_HOOK_ADDRESS=0x3752B89d43262fC9B4A4664e18c856dABd636DE2

# DynamoDB (pools & tokens persistence)
# HF_AWS_REGION=us-east-1
# HF_AWS_ACCESS_KEY_ID=...
# HF_AWS_SECRET_ACCESS_KEY=...
# DYNAMODB_TABLE_POOLS=hieroforge-pools
# DYNAMODB_TABLE_TOKENS=hieroforge-tokens

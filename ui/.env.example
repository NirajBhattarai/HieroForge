# Next.js / HieroForge UI – copy to ui/.env.local (do not commit)

# WalletConnect Project ID (required for HashPack). Get one at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Hedera network: mainnet | testnet | previewnet
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# Optional: RPC URL for balance/tx (default: https://testnet.hashio.io/api)
# NEXT_PUBLIC_RPC_URL=https://testnet.hashio.io/api

# Contract addresses (deployed 2026-03-14)
NEXT_PUBLIC_POOL_MANAGER_ADDRESS=0xc96474B027344d486a0963B3Da45F9a6c34AA96B
NEXT_PUBLIC_POSITION_MANAGER_ADDRESS=0x21ADCD6DE84afE088CD322B9ebdF7dfDF33f0B5A
NEXT_PUBLIC_ROUTER_ADDRESS=0x993027e4e258310DD872c132db5e9DEbF9578631
NEXT_PUBLIC_QUOTER_ADDRESS=0xb0649244102C565653994bAd0F7473914037d459
NEXT_PUBLIC_CHAIN_ID=296

# DynamoDB pools table (API routes read/write pools here; no hardcoded pool list)
# Create table with partition key: poolId (String)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# DYNAMODB_TABLE_POOLS=hieroforge-pools
# DYNAMODB_TABLE_TOKENS=hieroforge-tokens

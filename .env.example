# Hedera testnet deployment
# Copy to .env and set your values. Do not commit .env.

# EOA private key (with HBAR for gas on testnet). Get testnet HBAR from https://portal.hedera.com/faucet
PRIVATE_KEY=0x...

# Optional: override RPC URL (defaults to testnet from foundry.toml when using --rpc-url testnet)
# RPC_URL=https://testnet.hashio.io/api

# Hedera testnet / local node deployment
# Copy to .env and set your values. Do not commit .env.

# EOA private key (with HBAR for gas). Testnet: https://portal.hedera.com/faucet
PRIVATE_KEY=0x...

# Optional: treasury account for HTS token (EVM address). Defaults to signer address.
# TREASURY=0x...

# Optional: RPC URL for forge script (testnet or local Hedera EVM)
# Testnet: https://testnet.hashio.io/api
# Local node: http://127.0.0.1:7546 (or your Hedera local node EVM port)
# HEDERA_RPC_URL=https://testnet.hashio.io/api
